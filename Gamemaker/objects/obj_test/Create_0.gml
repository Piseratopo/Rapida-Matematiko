/* Comparison test case */
test_case_compare = [
   [["5", "3"], 1],
   [["3", "5"], -1],
   [["10.5", "10.5"], 0],
   [["5", "-3"], 1],
   [["-5", "3"], -1],
   [["3", "-5"], 1],
   [["-3", "5"], -1],
   [["-3", "-5"], 1],       // -3 is greater than -5
   [["-5", "-3"], -1],      // -5 is less than -3
   [["-10.5", "-10.5"], 0],
   [["-0.01", "-0.1"], 1],  // -0.01 is greater than -0.1
   [["0", "-5"], 1],
   [["-5", "0"], -1],
   [["0", "0"], 0],
   [["-0", "0"], 0]
];

