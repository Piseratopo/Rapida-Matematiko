{
    "installCommand": "npm install --legacy-peer-deps",
    "version": 2,
    "builds": [
        {
        "src": "main.js",
        "use": "@vercel/node"
        },
        {
        "src": "src/**/*",
        "use": "@vercel/static"
        }
    ],
    "routes": [
        {
        "src": "/(.*)",
        "dest": "./index.js",
        "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
        "headers": {
            "Access-Control-Allow-Origin": "*"
        }
        }
    ]
}